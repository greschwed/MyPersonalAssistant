rules_version = '2';

// Personal OS — usuário único.
// Tudo é negado por padrão; só passa request.auth.uid == ALLOWED_UID (definido abaixo).
// Quando rotacionar UID, atualizar AQUI e republish (firebase deploy --only firestore:rules).
service cloud.firestore {
  match /databases/{database}/documents {

    // === UIDs autorizados (substituir conforme rotacionar contas) ===
    function allowed() {
      return request.auth != null
          && request.auth.uid in [
               '2bt4pkNlyOgDm9VnSiR9IE6CyVR2',  // gregory.w.schwed@gmail.com
               'dyqBuBmYLYggDX6U12eKixOzdYR2'   // gregory.schwed@mevo.com.br
             ];
    }

    // Coleções do app — tudo passa pela função allowed()
    match /users/{userId} {
      allow read, write: if allowed() && userId == request.auth.uid;
    }
    match /entities/{entityId} {
      allow read, write: if allowed();
    }
    match /raw_captures/{captureId} {
      allow read, write: if allowed();
    }
    match /tasks/{taskId} {
      allow read, write: if allowed();
    }
    match /daily_logs/{logId} {
      allow read, write: if allowed();
    }
    match /memory_chunks/{chunkId} {
      allow read, write: if allowed();
    }
    match /mercado/{itemId} {
      allow read, write: if allowed();
    }
    match /audit_log/{eventId} {
      allow read: if allowed();
      allow create: if allowed();
      // imutável depois de criado
      allow update, delete: if false;
    }

    // bloqueia qualquer outra coleção por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
