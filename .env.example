# Personal OS — env vars
# Copie para .env.local (gitignored) e preencha.
# Valores reais ficam em C:\Users\grego\.personal-os-secrets\.env

# --- Firebase Client (público, vai no bundle) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin (server, SECRETO) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Em dev: caminho para o JSON. Em prod (Vercel): cole o private_key inteiro aqui.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PRIVATE_KEY=

# --- App config ---
USER_ID=gregorio
USER_TIMEZONE=America/Sao_Paulo
# Após o primeiro login, copiar aqui o UID do usuário Google (Firebase Console -> Auth -> Users)
ALLOWED_FIREBASE_UID=

# --- LLMs (Fase 3+) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Telegram (Fase 3) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USER_ID=

# --- Google (Fase 4) ---
GOOGLE_CALENDAR_ICAL_URL=
GOOGLE_SHEETS_FINANCE_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Programmatic + cron ---
API_SECRET=
CRON_SECRET=
